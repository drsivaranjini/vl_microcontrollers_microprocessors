---
interface Props {
  unit: number;
  title: string;
  summary: string;
  device: '8086' | '8051' | 'ARM';
  href: string;
}

const { unit, title, summary, device, href } = Astro.props;

const deviceColor: Record<Props['device'], string> = {
  '8086': 'bg-brand-500/10 text-brand-700',
  '8051': 'bg-accent/10 text-brand-900',
  ARM: 'bg-accent-warn/15 text-brand-900',
};
---

<article
  class="flex flex-col justify-between rounded-lab border border-border bg-surface p-5 shadow-(--shadow) transition hover:-translate-y-0.5 hover:shadow-lg"
>
  <div>
    <div class="mb-2 flex items-center gap-2">
      <span class="rounded-full bg-brand-900/5 px-2.5 py-0.5 text-xs font-semibold text-brand-700"
        >Unit {unit}</span
      >
      <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${deviceColor[device]}`}>{device}</span>
    </div>
    <h3 class="text-lg font-semibold text-text">{title}</h3>
    <p class="mt-1 text-sm text-text-muted">{summary}</p>
  </div>
  <a
    href={href}
    class="mt-4 inline-flex w-fit items-center gap-1 rounded-lab bg-brand-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-900"
  >
    Launch →
  </a>
</article>
