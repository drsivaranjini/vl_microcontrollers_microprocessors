---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface">
  <div
    class="mx-auto flex max-w-(--container-lab) flex-col gap-3 px-4 py-8 text-sm text-text-muted sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <p>&copy; {year} SRM Institute of Science and Technology — B.Tech Biomedical Engineering.</p>
    <nav aria-label="Footer">
      <ul class="flex flex-wrap gap-4">
        <li><a class="hover:text-brand-700" href={`${base}curriculum`}>Curriculum</a></li>
        <li><a class="hover:text-brand-700" href={`${base}references`}>References</a></li>
        <li><a class="hover:text-brand-700" href={`${base}about`}>About</a></li>
      </ul>
    </nav>
  </div>
</footer>
