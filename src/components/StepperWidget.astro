---
interface Props {
  addr?: number;
  degPerStep?: number;
}

const { addr = 0xc0, degPerStep = 45 } = Astro.props;
---

<div class="stepper-widget rounded-lab border border-border bg-scope-bg p-4" data-addr={addr} data-deg-per-step={degPerStep}>
  <svg class="stepper-svg mx-auto block w-full max-w-[280px]" viewBox="0 0 200 200" role="img" aria-label="Stepper motor rotor visualisation">
    <circle cx="100" cy="100" r="88" fill="none" stroke="var(--border)" stroke-width="2" />
    <!-- coils at N / E / S / W -->
    <circle class="coil-0" cx="100" cy="16" r="10" fill="var(--surface)" stroke="var(--text-muted)" stroke-width="1.5" />
    <circle class="coil-1" cx="184" cy="100" r="10" fill="var(--surface)" stroke="var(--text-muted)" stroke-width="1.5" />
    <circle class="coil-2" cx="100" cy="184" r="10" fill="var(--surface)" stroke="var(--text-muted)" stroke-width="1.5" />
    <circle class="coil-3" cx="16" cy="100" r="10" fill="var(--surface)" stroke="var(--text-muted)" stroke-width="1.5" />
    <g class="rotor" transform="rotate(0 100 100)">
      <circle cx="100" cy="100" r="52" fill="var(--surface)" stroke="var(--text-muted)" stroke-width="2" />
      <line x1="100" y1="100" x2="100" y2="54" stroke="var(--accent)" stroke-width="6" stroke-linecap="round" />
      <circle cx="100" cy="100" r="6" fill="var(--accent)" />
    </g>
  </svg>

  <dl class="mt-4 grid grid-cols-3 gap-2 text-center text-sm">
    <div>
      <dt class="text-text-muted">Direction</dt>
      <dd class="rd-dir font-mono text-base font-semibold text-white">—</dd>
    </div>
    <div>
      <dt class="text-text-muted">Steps</dt>
      <dd class="rd-steps font-mono text-base font-semibold text-white">0</dd>
    </div>
    <div>
      <dt class="text-text-muted">~RPM</dt>
      <dd class="rd-rpm font-mono text-base font-semibold text-white">0</dd>
    </div>
  </dl>
</div>

<style>
  .rotor {
    transform-box: fill-box;
    transition: transform 150ms linear;
  }
  @media (prefers-reduced-motion: reduce) {
    .rotor {
      transition: none;
    }
  }
  .coil-0,
  .coil-1,
  .coil-2,
  .coil-3 {
    transition: fill 100ms ease;
  }
  .energised {
    fill: var(--accent) !important;
  }
</style>

<script>
  // A real module script (no define:vars) so static imports are processed/bundled by Vite —
  // define:vars forces Astro to treat the script as is:inline, which cannot resolve imports.
  import { installEmuBus } from './emubus';
  import { StepperMotor } from './StepperMotor';

  document.querySelectorAll<HTMLDivElement>('.stepper-widget').forEach((root) => {
    const svg = root.querySelector<SVGSVGElement>('.stepper-svg');
    if (!svg) return;
    const addr = Number(root.dataset.addr ?? 0xc0);
    const degPerStep = Number(root.dataset.degPerStep ?? 45);
    installEmuBus();
    new StepperMotor(svg, { addr, degPerStep });
  });
</script>
