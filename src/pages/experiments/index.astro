---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperimentCard from '../../components/ExperimentCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('experiments')).sort(
  (a, b) => a.data.unit - b.data.unit || a.data.order - b.data.order,
);

const unitTitles: Record<number, string> = {
  1: 'Unit 1 — 8086 Microprocessor',
  2: 'Unit 2 — 8051 Microcontroller',
  3: 'Unit 3 — Interfacing',
  4: 'Unit 4 — ARM',
};

const byUnit = new Map<number, typeof entries>();
for (const e of entries) {
  const list = byUnit.get(e.data.unit) ?? [];
  list.push(e);
  byUnit.set(e.data.unit, list);
}
---

<BaseLayout title="Experiments" description="All 13 experiments for 21BMC302J, organised by unit.">
  <section class="mx-auto max-w-(--container-lab) px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold">Experiments</h1>
    <p class="mt-2 max-w-2xl text-text-muted">
      Labs 0–12 from the 21BMC302J manual. Each experiment page embeds a live simulator — read the theory,
      run the program, and observe the result in your browser.
    </p>

    {
      [1, 2, 3, 4].map((unit) => {
        const list = byUnit.get(unit) ?? [];
        return (
          <div class="mt-10">
            <h2 class="mb-4 text-lg font-semibold text-brand-700">{unitTitles[unit]}</h2>
            {list.length === 0 ? (
              <p class="text-sm italic text-text-muted">Content coming soon.</p>
            ) : (
              <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {list.map((e) => (
                  <ExperimentCard
                    unit={e.data.unit}
                    title={e.data.title}
                    summary={e.data.aim}
                    device={e.data.device}
                    href={`${base}experiments/${e.id}`}
                  />
                ))}
              </div>
            )}
          </div>
        );
      })
    }
  </section>
</BaseLayout>
