---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About the 21BMC302J virtual laboratory.">
  <section class="mx-auto max-w-(--container-lab) px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold">About this lab</h1>
    <div class="prose prose-slate mt-4 max-w-none">
      <p>
        This virtual laboratory covers Labs 0–12 of <strong>21BMC302J — Microcontrollers and its Application
        in Medicine</strong>, a course in the B.Tech Biomedical Engineering programme at SRM Institute of
        Science and Technology. It lets students read the theory, run the manual's programs on live,
        in-browser simulators, and observe the expected output — entirely for free, with no installation.
      </p>
      <p>
        Content coming soon: full course description, credit structure (3-0-2-4), and outcomes.
      </p>
    </div>
  </section>
</BaseLayout>
